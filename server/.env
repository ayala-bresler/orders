# --- Server ---
# 4000 is often blocked on Windows (Hyper-V excluded range 3957–4056) → EACCES
PORT=4100

# --- Master template (immutable, read-only) ---
# Defaults to the bundled server/templates/order.svg when unset.
# In production point this at the golden template on the network drive:
# MASTER_SVG_PATH=Z:\תיק מוצר\documents\order.svg

# --- Personalized SVG snapshots ---
# STORAGE_DIR=./storage/orders

# --- Model images (דגם picker) ---
# MODEL_IMAGES_DIR=Z:\תיק מוצר\documents\images\dept4\model

# --- PostgreSQL ---
# Either set DATABASE_URL, or the discrete PG* vars below.
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/hetz_haim
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=Admin
PGDATABASE=product_management

DXF_RECIPIENT_EMAIL=ayallabresler@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ayallabresler@gmail.com
SMTP_PASS=xfobljvotyzxmpbo
SMTP_FROM=ayallabresler@gmail.com
