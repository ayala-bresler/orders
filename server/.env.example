# --- Server ---
# Railway / Docker inject PORT at runtime. Local default is 3000.
PORT=3000
# Bind address (must be 0.0.0.0 for Railway / Docker)
# HOST=0.0.0.0
# Folder with the Vite client build (defaults to server/public)
# STATIC_DIR=./public
# Personalized SVG / DXF / PDF snapshots (use /tmp/... on Railway — ephemeral)
# STORAGE_DIR=./saved/orders

# Skip schema apply on boot (init.js still starts the server)
# SKIP_DB_INIT=true

# --- Session / inactivity ---
# Signed session TTL (default 15 minutes). Client inactivity matches this.
# SESSION_TTL_MS=900000
# HMAC secret for session tokens (required in production / Cloud Run)
# SESSION_SECRET=change-me-to-a-long-random-string

# --- Fallback SVG template (when no product size is resolved) ---
# Defaults to server/templates/sizes/12.svg when unset.
# MASTER_SVG_PATH=Z:\path\to\custom-template.svg

# --- DXF email delivery ---
# Recipient for exported DXF/PDF files
DXF_RECIPIENT_EMAIL=your@email.com

# Primary: classic SMTP (e.g. Gmail App Password) — local and cloud
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
# Gmail: App Password only (16 chars, no spaces) — NOT your normal Gmail password
# Create at: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM=your@email.com

# Optional fallback (HTTPS) if SMTP vars are unset:
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Orders <onboarding@resend.dev>
# Note: Railway Free/Hobby may block SMTP ports — upgrade or use Resend if timeouts occur.

# --- Model images (דגם picker) ---
# Defaults to server/assets/model-images (committed for Railway).
# Local override to live product folder:
# MODEL_IMAGES_DIR=Z:\תיק מוצר\documents\images\dept4\model

# --- PostgreSQL ---
# Either set DATABASE_URL, or the discrete PG* vars below.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/hetz_haim
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=hetz_haim
